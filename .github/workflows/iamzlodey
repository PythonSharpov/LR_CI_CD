import os
name: CI (pytest + ruff)

on:
  pull_request:
    branches: ["main", "master"]
  push:
    branches: ["main", "master"]

permissions:
  contents: read
  pull-requests: write

jobs:
  ci:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: "pip"
          cache-dependency-path: |
            requirements.txt

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          if [ -f requirements.txt ]; then pip install -r requirements.txt; fi
          pip install pytest ruff

      - name: Run unit tests (pytest)
        id: pytest
        continue-on-error: true
        run: |
          set -o pipefail
          pytest -q 2>&1 | tee pytest.log

      - name: Run Ruff (lint)
        id: ruff
        continue-on-error: true
        run: |
          set -o pipefail
          if [ -f ruff.toml ]; then
            ruff check --config ruff.toml --output-format=github . 2>&1 | tee ruff.log
          else
            ruff check --output-format=github . 2>&1 | tee ruff.log
          fi

      - name: Comment PR with failures
        if: github.event_name == 'pull_request' && (steps.pytest.outcome == 'failure' || steps.ruff.outcome == 'failure')
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require("fs");

            const read = (path) => {
              try { return fs.readFileSync(path, "utf8"); }
              catch (e) { return `Файл ${path} не найден или не читается: ${e.message}`; }
            };

            const truncate = (s, max) => {
              if (!s) return "";
              if (s.length <= max) return s;
              return s.slice(0, max) + `\n… (обрезано, всего ${s.length} символов)`;
            };

            const pytestFailed = "${{ steps.pytest.outcome }}" === "failure";
            const ruffFailed = "${{ steps.ruff.outcome }}" === "failure";

            let body = " CI не пройден\n\n";
            body += `• Pytest: ${pytestFailed ? " fail" : " ok"}\n`;
            body += `• Ruff: ${ruffFailed ? " fail" : " ok"}\n\n`;

            if (pytestFailed) {
              body += "### Pytest output\n";
              body += "```text\n" + truncate(read("pytest.log"), 6000) + "\n```\n\n";
            }

            if (ruffFailed) {
              body += "### Ruff output\n";
              body += "```text\n" + truncate(read("ruff.log"), 6000) + "\n```\n\n";
            }

            body += " Исправь ошибки и сделай push — workflow перезапустится автоматически.";

            await github.rest.issues.createComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
              body
            });

      - name: Fail job if checks failed
        if: steps.pytest.outcome == 'failure' || steps.ruff.outcome == 'failure'
